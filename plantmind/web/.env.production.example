# Production environment variables for Vercel
# Set these values in your Vercel project dashboard under Settings > Environment Variables

# Backend API endpoint - REQUIRED for production
# Should point to your deployed backend API
# Example: https://plantmind-api.herokuapp.com/api/v1
VITE_API_BASE=https://your-backend-api.com/api/v1

# Analytics and monitoring (optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

{
  "buildCommand": "cd plantmind/web && npm run build",
  "outputDirectory": "plantmind/web/dist",
  "framework": "vite",
  "devCommand": "cd plantmind/web && npm run dev",
  "env": {
    "VITE_API_BASE": {
      "description": "API base URL for backend endpoints"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
